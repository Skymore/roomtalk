# Copy to .env.compose before starting the local production-like stack, then
# always pass `--env-file .env.compose` to Docker Compose.
# .env.compose is ignored by Git; never commit real credentials.

ROOMTALK_PORT=3012
CLIENT_URL=http://localhost:3012
CLIENT_URLS=http://localhost:3012
# Optional generated env file used by scripts/local-production.mjs. Keep the
# default for ordinary development.
ROOMTALK_APP_ENV_FILE=.env.compose

POSTGRES_DB=message_system
POSTGRES_USER=roomtalk
# Keep this URL-safe because Compose embeds it in DATABASE_URL. For example:
# openssl rand -hex 32
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_HOST_PORT=54329

# These database ports bind only to loopback for maintenance and disposable
# integration tests. Redis stores only realtime state/cache.
REDIS_HOST_PORT=63799
ROOM_MESSAGES_CACHE_TTL_SECONDS=30

# Optional AI providers.
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ASSEMBLYAI_API_KEY=

# Local production uses the bundled SeaweedFS S3-compatible service. These
# credentials must be random and are shared only by the app and object store.
MEDIA_STORAGE_MODE=s3
MEDIA_BUCKET_NAME=roomtalk-media
MEDIA_STORAGE_REGION=us-east-1
MEDIA_STORAGE_ENDPOINT=http://object-storage:8333
# Required when browsers access S3 through an edge proxy or separate hostname.
MEDIA_STORAGE_PUBLIC_ENDPOINT=https://objects.example.com
MEDIA_STORAGE_FORCE_PATH_STYLE=true
LOCAL_S3_ACCESS_KEY_ID=replace-with-a-random-access-key
LOCAL_S3_SECRET_ACCESS_KEY=replace-with-a-long-random-secret
LOCAL_S3_HOST_PORT=8333
ROOMTALK_OBJECT_STORAGE_HOST_PATH=./runtime/object-storage

# Keep optional product surfaces disabled until their complete secret set is
# copied from the cloud environment into this local-only file.
CODE_AGENT_ENABLED=false
CODEX_CONNECTIONS_ENABLED=false
CODEX_AUTH_ENCRYPTION_KEY=
GITHUB_CONNECTIONS_ENABLED=false
GITHUB_AUTH_ENCRYPTION_KEY=

# AI outbox/worker. These match the current cloud architecture and can be
# enabled locally after provider credentials are configured.
AI_RUNNER_MODE=worker
OUTBOX_WORKER_ENABLED=true

# Optional Cloudflare Tunnel edge. Create runtime/cloudflared/config.yml and
# credentials.json, then start Compose with the edge profile.
CLOUDFLARE_TUNNEL_CONFIG_FILE=./runtime/cloudflared/config.yml
CLOUDFLARE_TUNNEL_CREDENTIALS_FILE=./runtime/cloudflared/credentials.json

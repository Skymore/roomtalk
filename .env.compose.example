# Copy to .env.compose before starting the local production-like stack.
# .env.compose is ignored by Git; never commit real credentials.

ROOMTALK_PORT=3012
CLIENT_URL=http://localhost:3012
CLIENT_URLS=http://localhost:3012

POSTGRES_DB=message_system
POSTGRES_USER=roomtalk
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Redis is internal to the Compose network and stores only realtime state/cache.
ROOM_MESSAGES_CACHE_TTL_SECONDS=30

# Optional AI providers.
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ASSEMBLYAI_API_KEY=

# Optional S3/Tigris-compatible media storage.
MEDIA_BUCKET_NAME=
MEDIA_STORAGE_REGION=auto
MEDIA_STORAGE_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Keep optional product surfaces disabled until their complete secret set is
# copied from the cloud environment into this local-only file.
CODE_AGENT_ENABLED=false
CODEX_CONNECTIONS_ENABLED=false
CODEX_AUTH_ENCRYPTION_KEY=
GITHUB_CONNECTIONS_ENABLED=false
GITHUB_AUTH_ENCRYPTION_KEY=

# AI outbox/worker. These match the current cloud architecture and can be
# enabled locally after provider credentials are configured.
AI_RUNNER_MODE=worker
OUTBOX_WORKER_ENABLED=true

# Copy to .env.compose before starting the local production-like stack, then
# always pass `--env-file .env.compose` to Docker Compose.
# .env.compose is ignored by Git; never commit real credentials.

ROOMTALK_PORT=3012
CLIENT_URL=http://localhost:3012
CLIENT_URLS=http://localhost:3012

POSTGRES_DB=message_system
POSTGRES_USER=roomtalk
# Keep this URL-safe because Compose embeds it in DATABASE_URL. For example:
# openssl rand -hex 32
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_HOST_PORT=54329

# These database ports bind only to loopback for maintenance and disposable
# integration tests. Redis stores only realtime state/cache.
REDIS_HOST_PORT=63799
ROOM_MESSAGES_CACHE_TTL_SECONDS=30

# Optional AI providers.
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ASSEMBLYAI_API_KEY=

# Local Compose stores media in the persistent media_data volume by default.
# Change the mode to s3 and fill the bucket settings to exercise the cloud path.
MEDIA_STORAGE_MODE=local
# Optional dedicated URL-signing key. When blank, local mode derives a distinct
# HMAC key from POSTGRES_PASSWORD.
LOCAL_MEDIA_SIGNING_SECRET=
MEDIA_BUCKET_NAME=
MEDIA_STORAGE_REGION=auto
MEDIA_STORAGE_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Keep optional product surfaces disabled until their complete secret set is
# copied from the cloud environment into this local-only file.
CODE_AGENT_ENABLED=false
CODEX_CONNECTIONS_ENABLED=false
CODEX_AUTH_ENCRYPTION_KEY=
GITHUB_CONNECTIONS_ENABLED=false
GITHUB_AUTH_ENCRYPTION_KEY=

# AI outbox/worker. These match the current cloud architecture and can be
# enabled locally after provider credentials are configured.
AI_RUNNER_MODE=worker
OUTBOX_WORKER_ENABLED=true

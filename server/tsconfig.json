{
    "compilerOptions": {
      "target": "es2019",
      "module": "Node20",
      "moduleResolution": "Node16",
      "outDir": "dist",
      "rootDir": ".",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "types": ["node"]
    },
    "include": [
      "./**/*.ts"
    ],
    "exclude": [
      "node_modules",
      "**/*.test.ts"
    ]
  }

# 服务端监听端口
PORT=3012

# 主客户端地址（用于 CORS 检查和部分服务的公开回调地址）
CLIENT_URL=http://localhost:3011
# 可选：多个客户端 Origin，逗号分隔；生产长期多域名时使用
# CLIENT_URLS=https://room.ruit.me
NODE_ENV=development

# Redis 配置
REDIS_URL=redis://localhost:6379

# 持久化配置
# PostgreSQL 是唯一 durable store；Redis 只做实时状态和短 TTL 缓存。
PERSISTENCE_STORE=postgres
DATABASE_URL=postgres://user:password@localhost:5432/message_system
POSTGRES_SSL=false
POSTGRES_SSL_REJECT_UNAUTHORIZED=true
# Optional CA certificate for managed PostgreSQL providers with a custom root.
# Prefer POSTGRES_SSL_CA_BASE64 in production secrets to avoid multiline escaping.
POSTGRES_SSL_CA_BASE64=
# POSTGRES_SSL_CA="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
ROOM_MESSAGES_CACHE_TTL_SECONDS=30
# 每房间 room_events 有界重放窗口：默认保留 7 天、最多 10000 条，每小时清理。
ROOM_EVENT_RETENTION_DAYS=7
ROOM_EVENT_MAX_PER_ROOM=10000
ROOM_EVENT_PRUNE_INTERVAL_MS=3600000
# 已提交 canonical event 的 Socket fast path 最大序列化字节；超限只发送 headSeq hint。
ROOM_EVENT_FAST_PATH_MAX_BYTES=262144
ROOMTALK_INSTANCE_LEASE_TTL_MS=30000
ROOMTALK_INSTANCE_HEARTBEAT_MS=10000
ROOMTALK_RECOVERY_INTERVAL_MS=5000

# 私有媒体对象存储（S3-compatible）
# 当前生产使用 SeaweedFS，保留的回滚目标使用 Tigris，AWS 映射到 S3。
# 媒体消息只在数据库保存 metadata/object key，二进制内容写入对象存储。
MEDIA_STORAGE_MODE=s3
MEDIA_BUCKET_NAME=message-system-media
MEDIA_STORAGE_REGION=us-east-1
# 与 compose.yaml 一起本地开发时使用 loopback SeaweedFS endpoint。
MEDIA_STORAGE_ENDPOINT=http://127.0.0.1:8333
# Optional separate browser-facing S3 endpoint for presigned URLs behind a proxy.
MEDIA_STORAGE_PUBLIC_ENDPOINT=
MEDIA_STORAGE_FORCE_PATH_STYLE=true
MEDIA_STORAGE_CONNECTION_TIMEOUT_MS=3000
MEDIA_STORAGE_REQUEST_TIMEOUT_MS=15000
MEDIA_STORAGE_SOCKET_TIMEOUT_MS=10000
MEDIA_STORAGE_MAX_ATTEMPTS=2
MEDIA_STORAGE_SLOW_REQUEST_MS=2000
AWS_ACCESS_KEY_ID=YOUR_S3_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_S3_SECRET_ACCESS_KEY

# AI 模型配置
AI_MODEL=deepseek-v4-pro

# OpenRouter 配置（用于 Kimi、GLM、MiniMax、Grok、Gemini 等模型）
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_HTTP_REFERER=http://localhost:5173
OPENROUTER_APP_NAME=RoomTalk

# DeepSeek 官方 API（用于 DeepSeek V4 Pro，支持 prompt caching）
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY

# Anthropic 官方 API（用于 Claude Sonnet 5 / Opus 4.8，支持 prompt caching）
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# AssemblyAI（语音转文字，流式实时转写 Universal-3 Pro）。
# 未配置时语音消息仍可发送，仅“语音转文字”不可用。
ASSEMBLYAI_API_KEY=YOUR_ASSEMBLYAI_API_KEY

# Google 登录（OAuth Web Client ID）。Client ID 是公开值，后端用它校验 Google ID token audience。
GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_WEB_CLIENT_ID
# 可选：需要兼容多个 Web Client ID 时用逗号分隔。
GOOGLE_CLIENT_IDS=
